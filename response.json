{"resultCode":"0","resultMessage":"OK","rgonInfoDto":[{"rgonCd":"01","rgonNm":"北海道"},{"rgonCd":"02","rgonNm":"東北"},{"rgonCd":"03","rgonNm":"関東"},{"rgonCd":"99","rgonNm":"海外"}],"refSelectHTML":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n    <meta charset=\"UTF-8\"/>\n    <title>問合せ先選択</title>\n    <style>\n        body { font-family: \"Meiryo\", \"MS PGothic\", sans-serif; margin: 16px; }\n        .title { font-size: 20px; font-weight: bold; margin-bottom: 12px; }\n        .section { border: 1px solid #ccc; padding: 12px; margin-bottom: 12px; }\n        .section-title { font-weight: bold; margin-bottom: 8px; }\n        .row { display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 8px; }\n        .field { display: flex; flex-direction: column; min-width: 200px; }\n        label { font-size: 12px; margin-bottom: 4px; }\n        input[type=\"text\"] { padding: 4px; }\n        .buttons { display: flex; gap: 8px; }\n        table { width: 100%; border-collapse: collapse; }\n        th, td { border: 1px solid #ccc; padding: 6px; text-align: left; }\n        th { background: #f5f5f5; }\n        .footer { display: flex; justify-content: flex-end; gap: 8px; }\n    </style>\n</head>\n<body>\n    <div class=\"title\">問合せ先選択</div>\n\n    <div class=\"section\">\n        <div class=\"section-title\">\n            <button id=\"accordion\" type=\"button\">検索条件</button>\n        </div>\n        <div class=\"row\">\n            <div class=\"field\">\n                <label for=\"txtRefNm\">問合せ先名称</label>\n                <input id=\"txtRefNm\" name=\"txtRefNm\" type=\"text\" maxlength=\"100\"/>\n            </div>\n            <div class=\"field\">\n                <label for=\"txtRefKn\">問合せ先名称カナ</label>\n                <input id=\"txtRefKn\" name=\"txtRefKn\" type=\"text\" maxlength=\"200\"/>\n            </div>\n            <div class=\"field\">\n                <label for=\"telno\">電話番号</label>\n                <input id=\"telno\" name=\"telno\" type=\"text\" maxlength=\"13\"/>\n            </div>\n            <div class=\"field\" style=\"min-width: 280px;\">\n                <label for=\"urlAheadSearch\">URLアドレス</label>\n                <input id=\"urlAheadSearch\" name=\"urlAheadSearch\" type=\"text\" maxlength=\"256\"/>\n            </div>\n        </div>\n        <div class=\"row\">\n            <div class=\"field\" style=\"min-width: 100%;\">\n                <label>地域</label>\n                <div>\n                    <label style=\"margin-right: 12px;\">\n                        <input type=\"checkbox\" name=\"rgonCheck\"\n                               value=\"01\" checked=\"checked\"/>\n                        <span>北海道</span>\n                    </label><label style=\"margin-right: 12px;\">\n                        <input type=\"checkbox\" name=\"rgonCheck\"\n                               value=\"02\" checked=\"checked\"/>\n                        <span>東北</span>\n                    </label><label style=\"margin-right: 12px;\">\n                        <input type=\"checkbox\" name=\"rgonCheck\"\n                               value=\"03\" checked=\"checked\"/>\n                        <span>関東</span>\n                    </label><label style=\"margin-right: 12px;\">\n                        <input type=\"checkbox\" name=\"rgonCheck\"\n                               value=\"99\"/>\n                        <span>海外</span>\n                    </label>\n                </div>\n            </div>\n        </div>\n        <div class=\"buttons\">\n            <button id=\"clearEvent\" type=\"button\">クリア</button>\n            <button id=\"searchEvent\" type=\"button\">検索</button>\n        </div>\n    </div>\n\n    <div class=\"section\">\n        <div class=\"section-title\">\n            問合せ先一覧\n            <span style=\"margin-left: 8px;\">件数:</span>\n            <span id=\"record\">0</span>\n        </div>\n        <table>\n            <thead>\n            <tr>\n                <th>選択</th>\n                <th>問合せ先コード</th>\n                <th>問合せ先名称</th>\n                <th>問合せ先カナ</th>\n                <th>電話番号</th>\n                <th>都道府県</th>\n                <th>地域</th>\n                <th>URL</th>\n            </tr>\n            </thead>\n            <tbody>\n            </tbody>\n        </table>\n    </div>\n\n    <div class=\"footer\">\n        <button id=\"cancelEvent\" type=\"button\">キャンセル</button>\n        <button id=\"selectEvent\" type=\"button\">決定</button>\n    </div>\n</body>\n</html>\n"}